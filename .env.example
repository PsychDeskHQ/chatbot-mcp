# --- Gemini ---
# Get a key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Latest GA agentic model. Override if you want a different one.
GEMINI_MODEL=gemini-3.5-flash
# Comma-separated fallback models tried on 503/429 (most stable last).
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash
# Retries per model with exponential backoff (2s, 4s, 8s + jitter).
GEMINI_MAX_RETRIES=3
GEMINI_REQUEST_TIMEOUT_MS=30000

# --- Database ---
# Postgres DSN, e.g.:
DATABASE_URL=postgresql://user:password@localhost:5432/your_db

# --- Server ---
HOST=127.0.0.1
PORT=8000
NODE_ENV=development

# --- Optional ---
# Max tool-call rounds per user message (loop guard).
MAX_TOOL_ROUNDS=8
# Comma-separated allowed CORS origins. Use * for development only.
CORS_ORIGIN=*
# Rate limit: max requests per window per IP on POST /chat
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
# Winston log level: error | warn | info | debug
LOG_LEVEL=info
