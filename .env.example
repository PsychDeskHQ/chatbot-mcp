# --- Gemini ---
# Get a key from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Latest GA agentic model. Override if you want a different one.
GEMINI_MODEL=gemini-3.5-flash

# --- Database ---
# Postgres DSN. asyncpg format, e.g.:
DATABASE_URL=postgresql://user:password@localhost:5432/your_db

# --- Optional ---
# Max tool-call rounds per user message (loop guard).
MAX_TOOL_ROUNDS=8
# Server bind (used by `python main.py`).
HOST=127.0.0.1
PORT=8000
# Set to any non-empty value to enable uvicorn auto-reload in dev.
RELOAD=
